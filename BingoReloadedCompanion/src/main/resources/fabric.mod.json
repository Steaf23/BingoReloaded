{
  "schemaVersion": 1,
  "id": "bingoreloadedcompanion",
  "version": "${version}",

  "name": "BingoReloadedCompanion",
  "description": "Client companion mod for BingoReloaded",
  "authors": [
    "Steven"
  ],
  "contact": {},

  "license": "GPL-3.0",
  "icon": "assets/bingoreloadedcompanion/icon.png",

  "environment": "client",
  "entrypoints": {
    "fabric-datagen": ["io.github.steaf23.bingoreloadedcompanion.client.BingoReloadedCompanionDataGenerator"],
    "client": ["io.github.steaf23.bingoreloadedcompanion.client.BingoReloadedCompanionClient"],
    "main": ["io.github.steaf23.bingoreloadedcompanion.BingoReloadedCompanion"],
    "modmenu": ["io.github.steaf23.bingoreloadedcompanion.client.config.BingoReloadedCompanionModMenu"]
  },

  "mixins": [
    "bingoreloadedcompanion.mixins.json"
    ,{
      "config": "bingoreloadedcompanion.client.mixins.json",
      "environment": "client"
    }
  ],

  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~26.1.2",
    "java": ">=25",
    "fabric-api": "*"
  }
}
